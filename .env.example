# Variables d'environnement KopéAgri Caraïbes
# Copier ce fichier en .env et remplir les valeurs

# ===== SUPABASE (OBLIGATOIRE) =====
VITE_SUPABASE_URL=https://VOTRE_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=VOTRE_CLE_ANON

# ===== STRIPE (optionnel - pour paiements en ligne) =====
STRIPE_SECRET_KEY=*** ===== TWILIO (optionnel - pour notifications WhatsApp) =====
TWILIO_ACCOUNT_SID=*** ===== RESEND (optionnel - pour emails transactionnels) =====
RESEND_API_KEY=*** ===== QONTO (optionnel - pour synchronisation bancaire reelle) =====
QONTO_API_KEY=*** ===== MAPBOX (optionnel - pour cartes interactives) =====
VITE_MAPBOX_TOKEN=*** echo "OK"
